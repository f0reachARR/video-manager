# Compose profiles. The compose file gates infra and the app tier behind
# profiles so the same file works for several deployment shapes:
#
#   internal-postgres : run Postgres in compose (omit when using a managed DB)
#   internal-s3       : run MinIO in compose (omit when using AWS S3 / external)
#   app               : run the Go API + nginx + baked SPA bundle behind one port
#
# Default below preserves the host-mode dev workflow (./scripts/dev.sh): infra
# in compose, API + Vite on the host. For a fully containerized deployment use
# e.g. COMPOSE_PROFILES=internal-postgres,internal-s3,app
COMPOSE_PROFILES=internal-postgres,internal-s3

# Public port exposed by the compose-internal nginx (used when the "app"
# profile is active). Everything (SPA, /api, /files, /hocuspocus) is served
# through this single port.
NGINX_PORT=80

# Go API
HTTP_ADDR=:8080
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_USER=video
POSTGRES_PASSWORD=video
POSTGRES_DB=soiree
POSTGRES_PORT=5432
# DATABASE_URL is what host-mode processes (./scripts/dev.sh) use to reach
# Postgres on the published port. Compose containers (api, worker,
# hocuspocus) prefer DATABASE_URL_INTERNAL when set, so the same .env works
# for both host-mode and containerized deployments.
DATABASE_URL=postgres://video:video@localhost:5432/soiree?sslmode=disable
DATABASE_URL_INTERNAL=postgres://video:video@postgres:5432/soiree?sslmode=disable

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=videos

# S3 (Go API → object store).
#
# S3_ENDPOINT is what the host-mode API (./scripts/dev.sh) sees — i.e. the
# MinIO port mapped to localhost. Inside the compose network the API and
# worker containers reach MinIO at http://minio:9000; that is set separately
# via S3_ENDPOINT_INTERNAL so the same .env works for both modes. Drop the
# internal-s3 profile and override S3_ENDPOINT / S3_ENDPOINT_INTERNAL /
# S3_BUCKET / S3_ACCESS_KEY / S3_SECRET_KEY to point at AWS S3 instead.
S3_ENDPOINT=http://localhost:9000
S3_ENDPOINT_INTERNAL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=videos
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_USE_PATH_STYLE=true
S3_PRESIGN_TTL=10m
# Used as the BaseEndpoint for presigned URLs only (server-side ops still go
# through S3_ENDPOINT). Set this when S3_ENDPOINT is container-internal —
# the API needs to hand the browser a URL the browser can resolve. Leave
# empty for external S3 (the bucket's normal public URL already works).
S3_PRESIGN_ENDPOINT=

# Public base URL for HLS playback links handed to the browser. The API serves
# the HLS proxy at /videos/{id}/hls/*, but the browser reaches it through the
# reverse proxy's prefix (the "app" profile mounts the API under /api). The
# request-derived fallback can't know that prefix, so set this to your public
# origin INCLUDING the path prefix. Leave empty only if the API is exposed at
# the root with no prefix. Examples:
#   dev (Vite proxy):  http://localhost:5173/api
#   compose / prod:    https://your-domain/api
HLS_BASE_URL=

# tusd. The hook URL is what tusd POSTs to when an upload finishes. In dev
# (API on the host) keep host.docker.internal; when running the "app"
# profile the API runs as the "api" service so set this to
# http://api:8080/uploads/tus-hook (which is the compose default when the
# env var is unset).
TUSD_PORT=1080
TUSD_HOOK_URL=http://host.docker.internal:8080/uploads/tus-hook

# Hocuspocus (Phase 2: ScoutingNote collab editing)
HOCUSPOCUS_PORT=1234

# Worker (Phase 3: HLS encode pipeline).
#
# The API process runs the orchestrating River workers (probe / plan / encode
# dispatcher / finalize) and exposes /internal/worker/jobs/* for the external
# hls-worker process to claim ffmpeg work. The hls-worker has S3 credentials
# but no DB credentials — it only talks to the API over HTTP.
#
# In-process River concurrency. Probe and encode dispatchers are cheap (they
# block waiting for the hls-worker), so a modest concurrency is plenty.
WORKER_QUEUES=default,encode
WORKER_CONCURRENCY_DEFAULT=4
WORKER_CONCURRENCY_ENCODE=4

# Shared bearer token authenticating the hls-worker against the API. Generate
# with `openssl rand -hex 32`. When empty the /internal/worker endpoints
# respond 503, so it must be set before the worker can claim any jobs.
WORKER_AUTH_TOKEN=

# Settings consumed only by cmd/hls-worker. API_BASE_URL is the API the
# worker calls (use http://host.docker.internal:8080 from inside Docker or
# http://localhost:8080 from the host).
API_BASE_URL=http://localhost:8080
WORKER_ID=
WORKER_CONCURRENCY=1
WORKER_CLAIM_WAIT=25s
WORKER_HEARTBEAT_INTERVAL=30s

# Authentication (OIDC).
# Leave OIDC_ISSUER_URL empty to disable OIDC entirely; in that case turn on
# AUTH_DEV_BYPASS so the legacy X-User-Id header continues to work for local
# development and integration tests.
#
# When OIDC is enabled, SESSION_SECRET is required: a random base64 string of
# at least 32 bytes signs the session and transient state cookies.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_SCOPES=openid,profile,email
OIDC_POST_LOGOUT_URL=/

SESSION_SECRET=
SESSION_MAX_AGE=168h
COOKIE_SECURE=false       # set true in production (TLS required)
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

AUTH_DEV_BYPASS=true      # keeps X-User-Id picker working; set false in prod
