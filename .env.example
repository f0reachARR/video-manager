# Go API
HTTP_ADDR=:8080
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_USER=video
POSTGRES_PASSWORD=video
POSTGRES_DB=video_manager
POSTGRES_PORT=5432
DATABASE_URL=postgres://video:video@localhost:5432/video_manager?sslmode=disable

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=videos

# S3 (Go API → MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=videos
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_USE_PATH_STYLE=true
S3_PRESIGN_TTL=10m

# tusd
TUSD_PORT=1080
TUSD_HOOK_URL=http://host.docker.internal:8080/uploads/tus-hook

# Hocuspocus (Phase 2: ScoutingNote collab editing)
HOCUSPOCUS_PORT=1234

# Worker (Phase 3: HLS encode pipeline)
# scripts/dev.sh starts a second cmd/app process alongside the main API,
# polling only the "encode" queue so heavy HLS jobs don't compete with the
# API's probe / plan / finalize jobs. These DEV_WORKER_* vars apply ONLY to
# that second process — they're remapped to HTTP_ADDR / WORKER_QUEUES /
# WORKER_CONCURRENCY_* inside dev.sh so they don't leak into the API process.
#
# The main API process ignores them and uses the WORKER_QUEUES=default
# fallback baked into internal/config.
DEV_WORKER_HTTP_ADDR=:8081
DEV_WORKER_QUEUES=encode
DEV_WORKER_CONCURRENCY_DEFAULT=4
DEV_WORKER_CONCURRENCY_ENCODE=1

# Authentication (OIDC).
# Leave OIDC_ISSUER_URL empty to disable OIDC entirely; in that case turn on
# AUTH_DEV_BYPASS so the legacy X-User-Id header continues to work for local
# development and integration tests.
#
# When OIDC is enabled, SESSION_SECRET is required: a random base64 string of
# at least 32 bytes signs the session and transient state cookies.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_SCOPES=openid,profile,email
OIDC_POST_LOGOUT_URL=/

SESSION_SECRET=
SESSION_MAX_AGE=168h
COOKIE_SECURE=false       # set true in production (TLS required)
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

AUTH_DEV_BYPASS=true      # keeps X-User-Id picker working; set false in prod
